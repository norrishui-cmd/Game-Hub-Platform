---
import Base from "../../../layouts/Base.astro";
import GameCard from "../../../components/GameCard.astro";
import gamesData from "../../../../data/games.json";
import { LOCALES } from "../../../i18n/locales.js";
import { t } from "../../../i18n/ui.js";
import { slugify, collectTaxonomy } from "../../../lib/games.js";

export function getStaticPaths() {
  const platforms = collectTaxonomy(gamesData.games, "platforms");
  return LOCALES.flatMap((locale) =>
    platforms.map(({ label, slug }) => ({
      params: { locale, platform: slug },
      props: { label, games: gamesData.games.filter((g) => (g.platforms || []).some((x) => slugify(x) === slug)) },
    }))
  );
}

const { locale } = Astro.params;
const { label, games } = Astro.props;
const indexable = locale === "en" && games.length >= 3;
---
<Base
  locale={locale}
  title={`${label} | GameRadar`}
  description={t(locale, "platformMetaDesc", label, games.length)}
  pathSuffix={`/platform/${slugify(label)}/`}
  noindex={!indexable}
  indexableLocales={indexable ? ["en"] : []}
>
  <main class="wrap" style="padding-top:28px">
    <div class="crumb"><a href={`/${locale}/`}>{t(locale, "breadcrumbBack")}</a></div>
    <div class="rail-head">
      <h1><span class="bar" style="background:var(--teal)"></span>{label}</h1>
      <span class="count">{games.length} {t(locale, "countSuffix")}</span>
    </div>
    <div class="grid">{games.map((g) => <GameCard game={g} locale={locale} />)}</div>
  </main>
</Base>
