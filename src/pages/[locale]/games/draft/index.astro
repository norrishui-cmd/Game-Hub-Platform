---
import Base from "../../../../layouts/Base.astro";
import draftsData from "../../../../../data/drafts.json";
import { LOCALES } from "../../../../i18n/locales.js";
import { t } from "../../../../i18n/ui.js";
import { displayTitle } from "../../../../lib/games.js";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const games = draftsData.games;
---
<Base locale={locale} title={`${t(locale, "draftRadarTitle")} | GameRadar`} description="Internal page, not public." noindex={true} pathSuffix="/games/draft/">
  <div class="draft-list">
    <div class="crumb"><a href={`/${locale}/`}>{t(locale, "breadcrumbBack")}</a></div>
    <h1 class="detail-title" style="font-size:22px; margin-bottom:6px;">{t(locale, "draftRadarTitle")}</h1>
    <p class="detail-en" style="margin-bottom:22px;">{t(locale, "draftRadarDesc", games.length)}</p>
    {games.length === 0 && (
      <div class="empty"><b>{t(locale, "draftRadarEmptyTitle")}</b>{t(locale, "draftRadarEmptyBody")}</div>
    )}
    {games.map((g) => (
      <a class="draft-row" href={`/${locale}/games/draft/${g.slug}/`}>
        <span class="name">{displayTitle(g, locale)}</span>
        <span class="score">🔥 {g.hype} · {g.release}</span>
      </a>
    ))}
  </div>
</Base>
